# Copy to .env and fill in values before running

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://pioneer:pioneer@localhost:5432/pioneer

# Redis (broker + cache)
REDIS_URL=redis://localhost:6379/0

# Email — internal notifications
INQUIRY_NOTIFICATION_EMAIL=info@pioneerconsultants.com
DEFAULT_FROM_EMAIL=info@pioneerconsultants.com


# Sentry (leave blank for local)
SENTRY_DSN=
